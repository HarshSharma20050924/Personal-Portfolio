{
  "version": 2,
  "installCommand": "npm install",
  "builds": [
    {
      "src": "server/package.json",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/prisma/**"
        ]
      }
    },
    {
      "src": "admin/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/src/server.mjs"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/client/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/client/favicon.svg"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/admin(/.*)?",
      "dest": "/admin/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/client/index.html"
    }
  ]
}