// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Specifies the Prisma Client generator.
// This tells Prisma to generate the JavaScript/TypeScript client based on this schema.
generator client {
  provider = "prisma-client-js"
}

// Defines the database connection.
// It's set to use PostgreSQL and gets the connection URL from the .env file.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Model for the single row of general/hero information.
// Using a fixed ID ensures there's only one entry for the main site info.
model GeneralInfo {
  id          Int    @id @default(1)
  name        String
  title       String
  description String @db.Text
}

// Model for Skills.
// Each skill has a unique name and a proficiency level.
model Skill {
  id    Int    @id @default(autoincrement())
  name  String @unique
  level Int
}

// Model for Projects.
// Includes fields for all project details, with tags stored as an array of strings.
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  imageUrl    String
  tags        String[]
  liveUrl     String?
  repoUrl     String?
}

// Model for Blog Articles.
// Each article has a unique URL.
model Article {
  id      Int    @id @default(autoincrement())
  title   String
  excerpt String @db.Text
  date    String
  url     String @unique
}

// Model for Social Links.
model SocialLink {
  id   Int    @id @default(autoincrement())
  name String
  url  String
  icon String
}

// Model for Admin User.
// The username is unique for login purposes.
model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String // In a real-world app, this should be a hashed password for security.
}