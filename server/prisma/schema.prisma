// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model GeneralInfo {
  id              Int     @id @default(autoincrement())
  name            String
  title           String
  description     String
  profileImageUrl String
  email           String?
  phone           String?
  quote           String?
  resumeUrl       String?
  template        String  @default("default")
}

model Skill {
  id    Int    @id @default(autoincrement())
  name  String
  level Int
}

model Service {
  id          Int       @id @default(autoincrement())
  title       String
  tagline     String?
  description String
  icon        String    @default("Globe")
  projects    Project[]
}

model Project {
  id              Int      @id @default(autoincrement())
  title           String
  description     String
  imageUrl        String
  videoUrl        String?
  docUrl          String?
  tags            String[]
  liveUrl         String?
  repoUrl         String?
  huggingFaceUrl  String?
  featured        Boolean  @default(false)
  
  // Visibility Flags
  showInClient    Boolean  @default(true)
  showInFreelance Boolean  @default(false)

  challenge       String?
  challengeImage  String?
  outcome         String?
  outcomeImage    String?

  // Relation to Service
  serviceId       Int?
  serviceIds      Int[]     @default([])
  service         Service? @relation(fields: [serviceId], references: [id])
  media           ProjectMedia[]
}

model SocialLink {
  id              Int     @id @default(autoincrement())
  name            String
  url             String
  icon            String
  showInClient    Boolean  @default(true)
  showInFreelance Boolean  @default(false)
}

model Article {
  id              Int     @id @default(autoincrement())
  title           String
  excerpt         String
  content         String?
  imageUrl        String?
  date            String
  url             String?
  featured        Boolean @default(false)
  showInClient    Boolean  @default(true)
  showInFreelance Boolean @default(false)
}

model Experience {
  id              Int     @id @default(autoincrement())
  position        String
  company         String
  period          String
  description     String
  showInClient    Boolean  @default(true)
  showInFreelance Boolean @default(false)
}

model Education {
  id              Int     @id @default(autoincrement())
  degree          String
  institution     String
  period          String
  showInClient    Boolean  @default(true)
  showInFreelance Boolean @default(false)
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
  
  // New fields for Context & Freelance inquiries
  type      String?  @default("general") // 'general' or 'freelance'
  company   String?
  service   String?
  phone     String?
}

model BiometricCredential {
  id           String   @id @default(uuid())
  credentialId String   @unique
  deviceName   String?
  createdAt    DateTime @default(now())
}

model PlaygroundConfig {
  id                   Int     @id @default(autoincrement())
  heroTitle            String  @default("Playground Mode")
  heroSubtitle         String  @default("Experimenting with colors, shapes, and layouts.")
  bgType               String  @default("gradient")
  bgColor1             String  @default("#0f172a")
  bgColor2             String  @default("#1e293b")
  textColor            String  @default("#f8fafc")
  primaryColor         String  @default("#38bdf8")
  cardStyle            String  @default("glass")
  borderRadius         String  @default("rounded-2xl")
  showHero             Boolean @default(true)
  showSkills           Boolean @default(true)
  showProjects         Boolean @default(true)
  showContact          Boolean @default(true)
  animationSpeed       String  @default("normal")
  
  // Particles
  particleCount        Int     @default(200)
  particleSpread       Int     @default(10)
  particleBaseSize     Int     @default(100)
  moveParticlesOnHover Boolean @default(true)
  disableRotation      Boolean @default(false)
  particleSpeed        Float   @default(0.1)

  // Floating Lines
  flLineCount          Int     @default(10)
  flLineDistance       Float   @default(5.0)
  flBendRadius         Float   @default(5.0)
  flBendStrength       Float   @default(-0.5)
  flParallax           Boolean @default(true)
}

model ClientLedger {
  id              Int      @id @default(autoincrement())
  clientName      String
  project         String
  totalAmount     Float
  paidAmount      Float
  notes           String?
  status          String   @default("active")
  date            DateTime @default(now())
  invoiceNumber   String?
  emiDetails      String?  // JSON string
  remainingAmount Float    @default(0)
}

model AdminConfig {
  id               Int      @id @default(autoincrement())
  fcmToken         String?
  brochureLogo     String?
  brochurePhoto    String?  // Developer photo
  brochureName     String?  @default("SYSTEM LABS")
  brochureTitle    String?  @default("Premium Software Solutions")
  brochureSubtitle String?  @default("Builder • Harsh Sharma")
  contactEmail     String?  @default("hello@systemlabs.dev")
  contactPhone     String?  @default("+1 (555) 000-0000")
  contactAddress   String?  @default("Silicon Valley, CA")
  brochureSegments  String?  // JSON for dynamic content (Old field name)
  brochureSections  String?  // JSON for logic sections
  brochureServicesTitle String? @default("Service Solutions")
  trustPoints      String?  // JSON string
  brochurePricing  String?  // JSON for pricing guide
  brochureSocials  String?  // JSON for social links
  brochureProjects String?  // JSON of selected project IDs
  brochureManualProjects String? // JSON of manual project entries (title, image, link, etc)
  brochureTestimonials String? // JSON of selected testimonial IDs
  brochureWebsite   String?
  brochureWebsiteTitle String? // Display title shown instead of raw URL
  brochureProjectCustomizations String? // JSON string for customized project details
  customFields     String?  // JSON string
}

model ProjectMedia {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  type      String   @default("image") // "image" or "video"
  title     String?  // e.g., "Landing Page", "Contact Page"
}

model Testimonial {
  id              Int      @id @default(autoincrement())
  clientName      String
  company         String?
  text            String
  projectUrl      String?
  showInClient    Boolean  @default(true)
  showInFreelance Boolean  @default(false)
}