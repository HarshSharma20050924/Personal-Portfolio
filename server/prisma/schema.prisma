// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model GeneralInfo {
  id              Int     @id @default(1)
  name            String
  title           String
  description     String  @db.Text
  profileImageUrl String  @db.Text
  email           String?
  phone           String?
  quote           String? @db.Text
}


model Skill {
  id    Int    @id @default(autoincrement())
  name  String
  level Int
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String   @db.Text
  tags        String[]
  liveUrl     String?
  repoUrl     String?
}

model SocialLink {
  id   Int    @id @default(autoincrement())
  name String
  url  String
  icon String
}

model Article {
  id      Int    @id @default(autoincrement())
  title   String
  excerpt String
  date    String
  url     String
}